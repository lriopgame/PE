package com.tradebot.util;
import org.junit.Before;
import org.junit.Test;
import static org.junit.Assert.*;
public class PriceCalculatorTest {

    private PriceCalculator priceCalculator;
    @Before
    public void setUp() {
        priceCalculator = new PriceCalculator();
    }
    
    @Test
    public void testCalculateTotalPrice() {
        double result = priceCalculator.calculateTotalPrice(45000.0, 0.5);
        assertEquals(22500.0, result, 0.01);
    }
    
    @Test
    public void testCalculateCommission() {
        double commission = priceCalculator.calculateCommission(10000.0, 0.5);
        assertEquals(50.0, commission, 0.01);
    }
    
    @Test
    public void testCalculateFinalPrice() {
        double finalPrice = priceCalculator.calculateFinalPrice(100.0, 10.0, 1.0);
        assertEquals(1010.0, finalPrice, 0.01);
    }
    
    @Test
    public void testCalculateProfit() {
        double profit = priceCalculator.calculateProfit(100.0, 150.0, 10.0);
        assertEquals(500.0, profit, 0.01);
    }
    
    @Test
    public void testCalculateProfitPercentage() {
        double profitPercent = priceCalculator.calculateProfitPercentage(100.0, 150.0);
        assertEquals(50.0, profitPercent, 0.01);
    }


name: Test PriceCalculator

on:
  push:
    branches: [ main ]
