BUY_THRESHOLD = 50000
SELL_THRESHOLD = 51000

# Глобальное состояние бота
bot_state = {
    'balance_usdt': 10000.0,
    'balance_btc': 0.0
}

def check_price(current_price):
    # Проверяет цену и выполняет покупку или продажу
    if current_price < BUY_THRESHOLD:
        buy_btc(current_price)
        log_action("buy", current_price)
    elif current_price > SELL_THRESHOLD:
        sell_btc(current_price)
        log_action("sell", current_price)

def buy_btc(price):
    # Покупка BTC на все доступные USDT
    if bot_state['balance_usdt'] <= 0:
        print("Недостаточно USDT для покупки")
        return

    amount = bot_state['balance_usdt'] / price
    bot_state['balance_btc'] += amount
    bot_state['balance_usdt'] = 0.0

def sell_btc(price):
    # Продажа всего BTC за USDT
    if bot_state['balance_btc'] <= 0:
        print("Нет BTC для продажи")
        return

    amount_usdt = bot_state['balance_btc'] * price
    bot_state['balance_usdt'] += amount_usdt
    bot_state['balance_btc'] = 0.0

def log_action(action, price):
    print(f"{action.upper()} at ${price:,.2f}")

